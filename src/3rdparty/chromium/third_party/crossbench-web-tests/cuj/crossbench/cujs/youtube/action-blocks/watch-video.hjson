{
  pages: {
    Youtube: {
      blocks: {
        play-video: ../../../common-action-blocks/youtube/load-and-play-video.hjson
        video-wait: [
          {
            action: wait
            duration: 120s
          }
          {
            action: wait_for_element
            selector: .paused-mode video
            timeout: 5m
          }
        ]
      }
    }
  }
}
