{
  page-load: {
    template: ../../../common-action-blocks/basic/page-load.hjson
    args: {
      READY_STATE: any
      TARGET: _self
      PAGE_LOAD_TIMEOUT: 2m
    }
    unbound_args: [
      PAGE_URL
    ]
  }
  scroll: ../../../common-action-blocks/power-browsing/page-scroll.hjson
}
