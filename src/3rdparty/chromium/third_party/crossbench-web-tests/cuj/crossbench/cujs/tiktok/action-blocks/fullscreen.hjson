{
  template: ./base-template.hjson
  args: {
    SCREEN_SETTINGS: [
      {
        action: click
        source: touch
        pos: {
          selector: button[data-e2e='more-menu-icon']
          wait: true
        }
        verify: div[data-e2e='more-menu-popover_full-screen'] span
      }
      {
        action: click
        source: touch
        pos: {
          selector: div[data-e2e='more-menu-popover_full-screen'] span
          wait: true
        }
        verify: ":fullscreen"
      }
    ]
  }
  unbound_args: [
    PAGE_URL
    VIDEO_TIME
  ]
}
