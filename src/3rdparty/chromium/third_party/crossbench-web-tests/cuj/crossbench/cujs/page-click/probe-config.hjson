{
  template: ../../probe-config.hjson
  args: {
    TRACE_PROCESSOR_QUERIES: [
      {
        name: LCP for page load and link clicks
        sql:
          '''
            INCLUDE PERFETTO MODULE sql_packages.cujs.page_click.output;
            SELECT * FROM page_click_output;
          '''
      }
    ]
    METRIC_DEFINITIONS: [
      ./metrics.textproto
    ]
    TRACE_CONFIG: ../../trace-config/detailed-trace-config.pbtxt
  }
}
