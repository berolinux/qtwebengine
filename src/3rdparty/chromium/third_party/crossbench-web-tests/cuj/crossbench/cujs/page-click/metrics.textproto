query {
  # Selects id, page_load_time, link_load_time from the "page_click_output"
  # table.
  id: "page_click_output"
  table {
    table_name: "page_click_output"
    module_name: "sql_packages.cujs.page_click.output"
    column_names: "id"
    column_names: "page_load_time"
    column_names: "link_load_time"
  }
}

metric_spec: {
  id: "cuj.page_click.page_load_time"
  dimensions: "id"
  value: "page_load_time"
  query: {
    inner_query_id: "page_click_output"
  }
}

metric_spec: {
  id: "cuj.page_click.link_load_time"
  dimensions: "id"
  value: "link_load_time"
  query: {
    inner_query_id: "page_click_output"
  }
}
