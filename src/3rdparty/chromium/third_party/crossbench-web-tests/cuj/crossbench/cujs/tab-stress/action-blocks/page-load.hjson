[
  {
    action: get
    url: $[PAGE_URL]
    ready_state: $[READY_STATE]
    timeout: 3m
    target: $[TAB_TARGET]
  }
  {
    action: js
    path: ./scripts/on-page-load.js
    replacements: {
      PAGE_URL: $[PAGE_URL]
    }
  }
]
