{
  "page-open-$[INDEX_PREFIX]0": {
    template: ./page-open.hjson
    args: {
      PAGE_URL: https://www.amazon.com/Pampers-Sensitive-Water-Based-Diaper-Pop-Top/dp/B01C3H4ZTY/
      TARGET: _new_tab
      TAB_INDEX: $[INDEX_PREFIX]0
    }
    unbound_args: [
      INDEX_PREFIX
    ]
  }
