{
  template: ../../probe-config.hjson
  args: {
    TRACE_PROCESSOR_QUERIES: [
      {
        name: Graphics.Smoothness.PercentDroppedFrames3.AllSequences
        sql:
          '''
            INCLUDE PERFETTO MODULE sql_packages.cujs.video.dropped_frames;
            SELECT * FROM dropped_frames_output;
          '''
      }
    ]
    METRIC_DEFINITIONS: [
      ../../common-metrics/v2/video_dropped_frames.textproto
    ]
    TRACE_CONFIG: ../../trace-config/detailed-trace-config.pbtxt
  }
}
