{
  page-load: {
    template: ../../../common-action-blocks/basic/page-load.hjson
    args: {
      READY_STATE: complete
      PAGE_LOAD_TIMEOUT: 2m
    }
    unbound_args: [
      PAGE_URL
      TARGET
    ]
  }
  scroll: ../../../common-action-blocks/basic/scroll-entire-page.hjson
}
