{
  template: ../../probe-config.hjson
  args: {
    TRACE_PROCESSOR_QUERIES: [
      ../../common-metrics/v1/meminfo_total.hjson
      ../../common-metrics/v1/meminfo_per_iteration.hjson
      {
        template: ../../common-metrics/v1/uma_histogram_times.hjson
        args: {
          NAME: Browser.Tabs.TotalSwitchDuration3
          UNITS_IN_MS: 1
        }
      }
      {
        template: ../../common-metrics/v1/uma_histogram_times.hjson
        args: {
          NAME: PageLoad.PaintTiming.NavigationToFirstContentfulPaint
          UNITS_IN_MS: 1
        }
      }
    ]
    METRIC_DEFINITIONS: [
      ../../common-metrics/v2/meminfo_total.textproto
      ../../common-metrics/v2/meminfo_per_iteration.textproto
    ]
    TRACE_CONFIG: ../../trace-config/long-running-trace-config.pbtxt
  }
}
