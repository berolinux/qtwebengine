    PAGE_URL5: $[PAGE_URL0]
    PAGE_URL6: $[PAGE_URL0]
    PAGE_URL7: $[PAGE_URL0]
    PAGE_URL8: $[PAGE_URL0]
    PAGE_URL9: $[PAGE_URL0]
    SWITCH_RE0: tab-stress/multiprocess/frame-container/\?count=5
    SWITCH_RE1: $[SWITCH_RE0]
    SWITCH_RE2: $[SWITCH_RE0]
    SWITCH_RE3: $[SWITCH_RE0]
    SWITCH_RE4: $[SWITCH_RE0]
    SWITCH_RE5: $[SWITCH_RE0]
    SWITCH_RE6: $[SWITCH_RE0]
    SWITCH_RE7: $[SWITCH_RE0]
    SWITCH_RE8: $[SWITCH_RE0]
    SWITCH_RE9: $[SWITCH_RE0]
