query {
  id: "dom_complete_output_query"
  table {
    table_name: "dom_complete_output"
    module_name: "sql_packages.queries.dom_complete"
    column_names: "id"
    column_names: "it_id"
    column_names: "dom_complete"
  }
}

metric_spec: {
  id: "cuj.common-metrics.dom_complete"
  dimensions: "id"
  dimensions: "it_id"
  value: "dom_complete"
  query: {
    inner_query_id: "dom_complete_output_query"
  }
}

metric_spec: {
  id: "cuj.common-metrics.dom_interactive"
  dimensions: "id"
  dimensions: "it_id"
  value: "dom_interactive"
  query: {
    inner_query_id: "dom_complete_output_query"
  }
}
