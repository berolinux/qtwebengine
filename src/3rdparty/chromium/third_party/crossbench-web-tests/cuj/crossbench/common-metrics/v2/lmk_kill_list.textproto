query: {
  id: "lmk_kill_list_query"
  # Selects it_id, process_name, ts and other details from the "lmk_kill_list_output"
  # view.
  table {
    table_name: "lmk_kill_list_output"
    module_name: "sql_packages.queries.lmk_kill_list"

    # Dimension columns: iteration ID, process name and timestamp are used
    # to uniquely identify the lmk kill event.
    column_names: "it_id"
    column_names: "process_name"
    column_names: "ts"

    # Value columns:
    column_names: "oom_adj_score"
    column_names: "min_oom_score"
    column_names: "page_fault"
    column_names: "page_major_fault"
    column_names: "rss_in_bytes"
    column_names: "cache_in_bytes"
    column_names: "swap_in_bytes"
    column_names: "free_mem_kb"
    column_names: "free_swap_kb"
    column_names: "thrashing"
    column_names: "max_thrashing"
    column_names: "total_foreground_services"
  }
}

metric_spec: {
  id: "cuj.common-metrics.lmk_kill_list.oom_adj_score"
  query {
    inner_query_id: "lmk_kill_list_query"
  }
  dimensions: "it_id"
  dimensions: "process_name"
  dimensions: "ts"
  value: "oom_adj_score"
}

metric_spec: {
  id: "cuj.common-metrics.lmk_kill_list.min_oom_score"
  query {
    inner_query_id: "lmk_kill_list_query"
  }
