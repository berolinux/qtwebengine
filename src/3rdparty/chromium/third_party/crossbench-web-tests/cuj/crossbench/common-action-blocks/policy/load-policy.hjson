[
  {
    action: get
    url: chrome://policy/test
    target: _new_tab
    ready_state: complete
  }
  {
    action: js
    path: ./scripts/load-policy.js
    replacements: {
      POLICY_JSON: $[POLICY_JSON]
    }
  }
  {
    action: close_tab
  }
]
