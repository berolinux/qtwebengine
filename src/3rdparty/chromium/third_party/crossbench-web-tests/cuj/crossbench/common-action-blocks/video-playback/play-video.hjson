{
  pages: {
    VideoCUJ: {
      actions: [
        {
          action: get
          url: https://storage.googleapis.com/chromiumos-test-assets-public/tast/cros/video/video_20250716.html
          ready_state: complete
        }
        {
          action: js
          script: startPlaying("$[FILE_NAME]", $[UNMUTE_PLAYER])
        }
          // Element ready doesn't mean stream is ready, so wait for a bit
        {
          action: wait_for_element
          selector: .videotile
          timeout: 10s
        }
          // Wait until the video has finished playing
        {
          action: wait_for_condition
          condition: return document.querySelector('.videotile').ended
          timeout: 60s
        }
      ]
    }
  }
}
