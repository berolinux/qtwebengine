{
  actions: [
    {
      action: js
      script: performance.mark('scroll-begin');
    }
    {
      action: scroll
      source: touch
      selector: $[SCROLL_SELECTOR]
      distance: 512
      duration: 0.3s
    }
    {
      action: wait
      duration: 0.5s
    }
    {
      action: scroll
      source: touch
      selector: $[SCROLL_SELECTOR]
      distance: 512
      duration: 0.3s
    }
    {
      action: wait
      duration: 0.5s
    }
    {
      action: scroll
      source: touch
      selector: $[SCROLL_SELECTOR]
      distance: 512
      duration: 0.3s
    }
    {
      action: wait
      duration: 0.5s
    }
    {
      action: scroll
      source: touch
      selector: $[SCROLL_SELECTOR]
      distance: 512
      duration: 0.3s
    }
    {
      action: wait
      duration: 0.5s
    }
    {
      action: scroll
      source: touch
      selector: $[SCROLL_SELECTOR]
      distance: 512
      duration: 0.3s
    }
    {
      action: js
      script:
        '''
        performance.mark('scroll-end', {detail: document.querySelector('$[SCROLL_END_DISTANCE_SELECTOR]').scrollTop});
        performance.measure('scroll', 'scroll-begin', 'scroll-end');
        '''
    }
    {
      action: wait
      duration: 0.5s
    }
  ]
}
