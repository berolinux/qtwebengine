data_sources: {
  config {
    name: "android.input.inputevent"
    target_buffer: 6
    android_input_event_config {
      mode: TRACE_MODE_TRACE_ALL
    }
  }
}
write_into_file: true
file_write_period_ms: 5000
max_file_size_bytes: 1073741824
flush_period_ms: 30000
